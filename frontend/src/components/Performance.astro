---
---

<section class="perf" id="performance">
  <div class="perf-inner">

    <div class="perf-header">
      <div class="perf-eyebrow">Benchmarks</div>
      <h2 class="perf-title">Performance that speaks.</h2>
      <p class="perf-sub">Tested on mid-range hardware. Results vary by system — your gains may be higher.</p>
    </div>

    <div class="perf-rig">
      <span class="rig-label">Test Rig</span>
      <div class="rig-specs">
        <span>AMD Ryzen 5 7535U</span>
        <span class="rig-sep">·</span>
        <span>Radeon 680M</span>
        <span class="rig-sep">·</span>
        <span>16GB DDR5 4800MT</span>
        <span class="rig-sep">·</span>
        <span>Render distance 8 chunks · 1200p</span>
      </div>
    </div>

    <div class="charts-grid">
      <div class="chart-card">
        <h3 class="chart-title">Average FPS — Minecraft 1.21.11</h3>
        <p class="chart-sub">Higher is better</p>
        <div class="bar-chart" id="fpsChart"></div>
      </div>
      <div class="chart-card">
        <h3 class="chart-title">Chunk Load Time — Teleport to new area</h3>
        <p class="chart-sub">Lower is better</p>
        <div class="bar-chart" id="chunkChart"></div>
      </div>
    </div>

    <p class="perf-disclaimer">
      * Benchmarks are approximate. "Competitor Pack" represents a popular general-purpose optimization pack.
      All packs tested on the same hardware and settings. Nividium tested on NVIDIA GPU only.
    </p>

  </div>
</section>

<style>
.perf {
  padding: 80px 24px;
  border-top: 1px solid var(--border);
}
.perf-inner { max-width: 1100px; margin: 0 auto; }

.perf-header { text-align: center; margin-bottom: 32px; }
.perf-eyebrow {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent2);
  border: 1px solid rgba(0,144,255,0.3);
  padding: 4px 14px;
  border-radius: 100px;
  margin-bottom: 16px;
}
.perf-title {
  font-family: var(--font-head);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  margin-bottom: 10px;
}
.perf-sub { color: var(--muted); font-size: 1rem; }

.perf-rig {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 20px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}
.rig-label {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--accent2);
  white-space: nowrap;
}
.rig-specs { display: flex; gap: 8px; flex-wrap: wrap; font-size: 0.83rem; color: var(--muted); }
.rig-sep { color: var(--border); }

.charts-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}
@media (max-width: 750px) { .charts-grid { grid-template-columns: 1fr; } }

.chart-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.chart-title {
  font-family: var(--font-head);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
}
.chart-sub {
  font-size: 0.78rem;
  color: var(--muted);
  margin-bottom: 20px;
}

.bar-chart {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.bar-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.bar-row-label {
  font-size: 0.82rem;
  color: var(--muted);
  font-weight: 500;
}

.bar-track {
  height: 30px;
  background: var(--surface2);
  border-radius: 49px;
  position: relative;
  overflow: hidden;
}

.bar-track-inner {
  position: absolute;
  inset: 0;
  border-radius: 999px;
  pointer-events: none;
}
.bar-fill::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 999px;
  box-shadow: 0 0 18px 4px var(--bar-glow);
}
.bar-fill {
  height: 100%;
  border-radius: 48px;
  width: 0%;
  transition: width 1.1s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  align-items: center;
  padding-left: 14px;
  position: relative;
}
/* Glow sits outside the clipping context on a pseudo element */
.bar-glow {
  position: absolute;
  inset: 0;
  border-radius: 999px;
  pointer-events: none;
  width: 0%;
  transition: width 1.1s cubic-bezier(0.16, 1, 0.3, 1);
}
.bar-value {
  font-family: var(--font-head);
  font-size: 0.88rem;
  font-weight: 700;
  color: #fff;
  margin-left: 24px;
  white-space: nowrap;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
}

.perf-disclaimer {
  margin-top: 28px;
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  text-align: center;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
}
</style>

<script>
  const COLORS = {
    sodium:     { fill: "#0090ff", glow: "rgba(0,144,255,0.6)"   },
    vulkan:     { fill: "#dc3232", glow: "rgba(220,50,50,0.6)"   },
    nividium:   { fill: "#50c850", glow: "rgba(80,200,80,0.6)"   },
    competitor: { fill: "#c878ff", glow: "rgba(200,120,255,0.6)" },
    vanilla:    { fill: "#788291", glow: "rgba(120,130,145,0.4)" },
  };

  const FPS_DATA = [
    { label: "Nividium",        key: "nividium",   value: 1000 },
    { label: "VulkanMod",       key: "vulkan",     value: 620  },
    { label: "Sodium",          key: "sodium",     value: 374  },
    { label: "Competitor Pack", key: "competitor", value: 241  },
    { label: "Vanilla",         key: "vanilla",    value: 118  },
  ];

  const CHUNK_DATA = [
    { label: "VulkanMod",       key: "vulkan",     value: 200 },
    { label: "Nividium",        key: "nividium",   value: 245 },
    { label: "Sodium",          key: "sodium",     value: 290 },
    { label: "Vanilla",         key: "vanilla",    value: 480 },
    { label: "Competitor Pack", key: "competitor", value: 320 },
  ];

  function buildChart(containerId, data, unit) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const max = Math.max(...data.map(d => d.value));

    data.forEach(d => {
      const pct = (d.value / max) * 100;
      const col = COLORS[d.key];

      const row = document.createElement('div');
      row.className = 'bar-row';
      // Two-layer approach: inner clip keeps bar rounded, outer glow div sits outside clip
      row.innerHTML = `
        <span class="bar-row-label">${d.label}</span>
        <div class="bar-track">
          <div class="bar-track-inner">
            <div class="bar-fill" data-pct="${pct}" style="background: ${col.fill}; --bar-glow: ${col.glow}; border-radius: 4px;"">
              <span style="margin-left: 4px;" class="bar-value">${d.value}${unit}</span>
            </div>
          </div>
          <div class="bar-glow" data-pct="${pct}" style="box-shadow: 0 0 18px 4px ${col.glow};"></div>
        </div>
      `;
      container.appendChild(row);
    });
  }

  buildChart('fpsChart',   FPS_DATA,   ' fps');
  buildChart('chunkChart', CHUNK_DATA, 'ms');

  // Animate bars in on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('[data-pct]').forEach(el => {
          const htmlEl = el as HTMLElement;
          htmlEl.style.width = htmlEl.dataset.pct + '%';
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.chart-card').forEach(card => observer.observe(card));
</script>