---
<footer class="footer">
  <div class="footer-inner">
    <span class="footer-logo">Opti<span>Ark</span></span>
    <p class="footer-text">A high-performance Minecraft optimization modpack. Not affiliated with Mojang.</p>
    <div class="footer-links">
      <a href="https://github.com/arc360alt/OptiArk-New" target="_blank">GitHub</a>
      <a href="/news">News</a>
      <a href="/specs">Specs</a>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--border);
  padding: 40px 24px;
  margin-top: 80px;
}
.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-align: center;
}
.footer-logo {
  font-family: var(--font-head);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text);
}
.footer-logo span { color: var(--accent); }
.footer-text { color: var(--muted); font-size: 0.85rem; max-width: 400px; }
.footer-links { display: flex; gap: 20px; }
.footer-links a { color: var(--muted); font-size: 0.85rem; }
.footer-links a:hover { color: var(--accent); text-decoration: none; }
</style>
